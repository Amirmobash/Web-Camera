<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <appSettings>
    <!--
      Nur diese Kamera verwenden:
      1) Programm einmal starten und Kameranamen im Statusbereich ablesen.
      2) Den Namen hier eintragen, z. B. Logitech HD Webcam C270.
      3) Wenn leer, wird nur die erste gefundene Kamera verwendet; es gibt keine Kamera-Auswahl im UI.
    -->
    <add key="TargetCameraName" value="" />

    <!-- Exact oder Contains -->
    <add key="CameraMatchMode" value="Contains" />
  </appSettings>
</configuration>
